# Environment Configuration Template
# Copy this file to .env in the petplus directory and adjust values as needed

# Backend API URL
# Local Development
REACT_APP_API_URL=http://localhost:5000

# Production (change this when deploying)
# REACT_APP_API_URL=https://your-api-domain.com

# Enable Debug Logging (optional)
# REACT_APP_DEBUG=true

# Firebase Configuration is handled in src/components/firebase.jsx
# If you need to override Firebase settings, add them here:
# REACT_APP_FIREBASE_API_KEY=your_key_here
# REACT_APP_FIREBASE_AUTH_DOMAIN=your_domain_here
